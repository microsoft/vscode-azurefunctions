{
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "es2022",
        "outDir": "out",
        "lib": [
            "es2022"
        ],
        "sourceMap": true,
        "rootDir": ".",
        "noUnusedLocals": true,
        "noImplicitThis": true,
        "noImplicitReturns": true,
        "strictNullChecks": true,
        "skipLibCheck": true, // needed to ignore vscode-jsonrpc package
        "noUnusedParameters": true,
        "allowSyntheticDefaultImports": true,
        "types": [
            "mocha",
            "node"
        ]
    },
    "exclude": [
        "**/node_modules",
        ".vscode-test",
        "**/dist",
        "**/out"
    ]
}
